{
  "uid": "waito-overview",
  "title": "Waito Overview",
  "tags": ["waito", "ticketing"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "5s",
  "panels": [
    {
      "id": 100,
      "title": "Bottleneck Overview",
      "type": "row",
      "collapsed": false,
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1},
      "panels": []
    },
    {
      "id": 1,
      "title": "HTTP p95 Latency",
      "type": "stat",
      "gridPos": {"x": 0, "y": 1, "w": 4, "h": 4},
      "fieldConfig": {"defaults": {"unit": "s", "decimals": 3}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"waito-api\",uri!=\"/actuator/prometheus\"}[1m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP 5xx Rate",
      "type": "stat",
      "gridPos": {"x": 4, "y": 1, "w": 4, "h": 4},
      "fieldConfig": {"defaults": {"unit": "ops", "decimals": 2}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"waito-api\",status=~\"5..\"}[1m]))",
          "legendFormat": "5xx/sec"
        }
      ]
    },
    {
      "id": 3,
      "title": "Active HTTP Requests",
      "type": "stat",
      "gridPos": {"x": 8, "y": 1, "w": 4, "h": 4},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "sum(http_server_requests_active_seconds_gcount{application=\"waito-api\"})",
          "legendFormat": "active"
        }
      ]
    },
    {
      "id": 4,
      "title": "Tomcat Busy Threads",
      "type": "stat",
      "gridPos": {"x": 12, "y": 1, "w": 4, "h": 4},
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 1, "min": 0, "max": 100}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "sum(waito_api_tomcat_threads_busy{application=\"waito-api\",name=\"http-nio-8080\"}) / sum(waito_api_tomcat_threads_max{application=\"waito-api\",name=\"http-nio-8080\"}) * 100",
          "legendFormat": "busy/max"
        }
      ]
    },
    {
      "id": 5,
      "title": "Hikari Active Connections",
      "type": "stat",
      "gridPos": {"x": 16, "y": 1, "w": 4, "h": 4},
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 1, "min": 0, "max": 100}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "sum(hikaricp_connections_active{application=\"waito-api\"}) / sum(hikaricp_connections_max{application=\"waito-api\"}) * 100",
          "legendFormat": "active/max"
        }
      ]
    },
    {
      "id": 6,
      "title": "Kafka Consumer Lag",
      "type": "stat",
      "gridPos": {"x": 20, "y": 1, "w": 4, "h": 4},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "sum(clamp_min(kafka_consumergroup_lag, 0))",
          "legendFormat": "lag"
        }
      ]
    },
    {
      "id": 101,
      "title": "HTTP",
      "type": "row",
      "collapsed": false,
      "gridPos": {"x": 0, "y": 5, "w": 24, "h": 1},
      "panels": []
    },
    {
      "id": 10,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 6, "w": 8, "h": 8},
      "fieldConfig": {"defaults": {"unit": "ops", "decimals": 2}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"waito-api\",uri!=\"/actuator/prometheus\"}[1m])) by (method, uri, status)",
          "legendFormat": "{{method}} {{uri}} {{status}}"
        }
      ]
    },
    {
      "id": 11,
      "title": "HTTP Latency by URI",
      "type": "timeseries",
      "gridPos": {"x": 8, "y": 6, "w": 8, "h": 8},
      "fieldConfig": {"defaults": {"unit": "s", "decimals": 3}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"waito-api\",uri!=\"/actuator/prometheus\"}[1m])) by (le, method, uri))",
          "legendFormat": "p95 {{method}} {{uri}}"
        },
        {
          "maxDataPoints": 11000,
          "refId": "B",
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"waito-api\",uri!=\"/actuator/prometheus\"}[1m])) by (le, method, uri))",
          "legendFormat": "p99 {{method}} {{uri}}"
        }
      ]
    },
    {
      "id": 12,
      "title": "HTTP Active Requests",
      "type": "timeseries",
      "gridPos": {"x": 16, "y": 6, "w": 8, "h": 8},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "sum(http_server_requests_active_seconds_gcount{application=\"waito-api\"}) by (method, uri, status)",
          "legendFormat": "{{method}} {{uri}} {{status}}"
        }
      ]
    },
    {
      "id": 102,
      "title": "Application / Tomcat",
      "type": "row",
      "collapsed": false,
      "gridPos": {"x": 0, "y": 14, "w": 24, "h": 1},
      "panels": []
    },
    {
      "id": 20,
      "title": "Tomcat Threads",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 15, "w": 8, "h": 8},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "sum(waito_api_tomcat_threads_busy{application=\"waito-api\",name=\"http-nio-8080\"}) by (name)",
          "legendFormat": "busy {{name}}"
        },
        {
          "maxDataPoints": 11000,
          "refId": "B",
          "expr": "sum(waito_api_tomcat_threads_current{application=\"waito-api\",name=\"http-nio-8080\"}) by (name)",
          "legendFormat": "current {{name}}"
        },
        {
          "maxDataPoints": 11000,
          "refId": "C",
          "expr": "sum(waito_api_tomcat_threads_max{application=\"waito-api\",name=\"http-nio-8080\"}) by (name)",
          "legendFormat": "max {{name}}"
        }
      ]
    },
    {
      "id": 21,
      "title": "Tomcat Connections",
      "type": "timeseries",
      "gridPos": {"x": 8, "y": 15, "w": 8, "h": 8},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "sum(waito_api_tomcat_connections_current{application=\"waito-api\",name=\"http-nio-8080\"}) by (name)",
          "legendFormat": "current {{name}}"
        },
        {
          "maxDataPoints": 11000,
          "refId": "B",
          "expr": "sum(waito_api_tomcat_connections_max{application=\"waito-api\",name=\"http-nio-8080\"}) by (name)",
          "legendFormat": "max {{name}}"
        }
      ]
    },
    {
      "id": 22,
      "title": "JVM Thread States",
      "type": "timeseries",
      "gridPos": {"x": 16, "y": 15, "w": 8, "h": 8},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "jvm_threads_states_threads{application=\"waito-api\"}",
          "legendFormat": "{{state}}"
        }
      ]
    },
    {
      "id": 23,
      "title": "API CPU",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 23, "w": 8, "h": 8},
      "fieldConfig": {"defaults": {"unit": "percentunit", "decimals": 3, "min": 0}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "process_cpu_usage{application=\"waito-api\"}",
          "legendFormat": "process"
        },
        {
          "maxDataPoints": 11000,
          "refId": "B",
          "expr": "system_cpu_usage{application=\"waito-api\"}",
          "legendFormat": "system"
        }
      ]
    },
    {
      "id": 24,
      "title": "JVM Memory Used",
      "type": "timeseries",
      "gridPos": {"x": 8, "y": 23, "w": 8, "h": 8},
      "fieldConfig": {"defaults": {"unit": "mbytes", "decimals": 2}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "sum(jvm_memory_used_bytes{application=\"waito-api\"}) by (area) / 1024 / 1024",
          "legendFormat": "{{area}}"
        }
      ]
    },
    {
      "id": 25,
      "title": "GC Pause / Overhead",
      "type": "timeseries",
      "gridPos": {"x": 16, "y": 23, "w": 8, "h": 8},
      "fieldConfig": {"defaults": {"unit": "s", "decimals": 4}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "rate(jvm_gc_pause_seconds_sum{application=\"waito-api\"}[1m])",
          "legendFormat": "pause seconds/sec"
        },
        {
          "maxDataPoints": 11000,
          "refId": "B",
          "expr": "jvm_gc_overhead{application=\"waito-api\"}",
          "legendFormat": "overhead ratio"
        }
      ]
    },
    {
      "id": 103,
      "title": "Database / Hikari / MySQL",
      "type": "row",
      "collapsed": false,
      "gridPos": {"x": 0, "y": 31, "w": 24, "h": 1},
      "panels": []
    },
    {
      "id": 30,
      "title": "Hikari Pool",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 32, "w": 8, "h": 8},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "hikaricp_connections_active{application=\"waito-api\"}",
          "legendFormat": "active"
        },
        {
          "maxDataPoints": 11000,
          "refId": "B",
          "expr": "hikaricp_connections_idle{application=\"waito-api\"}",
          "legendFormat": "idle"
        },
        {
          "maxDataPoints": 11000,
          "refId": "C",
          "expr": "hikaricp_connections_pending{application=\"waito-api\"}",
          "legendFormat": "pending"
        },
        {
          "maxDataPoints": 11000,
          "refId": "D",
          "expr": "hikaricp_connections_max{application=\"waito-api\"}",
          "legendFormat": "max"
        }
      ]
    },
    {
      "id": 31,
      "title": "Hikari Acquire / Usage Max",
      "type": "timeseries",
      "gridPos": {"x": 8, "y": 32, "w": 8, "h": 8},
      "fieldConfig": {"defaults": {"unit": "s", "decimals": 4}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "hikaricp_connections_acquire_seconds_max{application=\"waito-api\"}",
          "legendFormat": "acquire max"
        },
        {
          "maxDataPoints": 11000,
          "refId": "B",
          "expr": "hikaricp_connections_usage_seconds_max{application=\"waito-api\"}",
          "legendFormat": "usage max"
        }
      ]
    },
    {
      "id": 32,
      "title": "Hikari Timeouts",
      "type": "timeseries",
      "gridPos": {"x": 16, "y": 32, "w": 8, "h": 8},
      "fieldConfig": {"defaults": {"unit": "ops", "decimals": 3}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "rate(hikaricp_connections_timeout_total{application=\"waito-api\"}[1m])",
          "legendFormat": "timeouts/sec"
        }
      ]
    },
    {
      "id": 33,
      "title": "MySQL QPS / TPS",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 40, "w": 8, "h": 8},
      "fieldConfig": {"defaults": {"unit": "ops", "decimals": 2}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "rate(mysql_global_status_queries[1m])",
          "legendFormat": "qps"
        },
        {
          "maxDataPoints": 11000,
          "refId": "B",
          "expr": "sum(rate(mysql_global_status_commands_total{command=~\"commit|rollback\"}[1m]))",
          "legendFormat": "tps"
        }
      ]
    },
    {
      "id": 34,
      "title": "MySQL Threads / Connections",
      "type": "timeseries",
      "gridPos": {"x": 8, "y": 40, "w": 8, "h": 8},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "mysql_global_status_threads_connected",
          "legendFormat": "threads connected"
        },
        {
          "maxDataPoints": 11000,
          "refId": "B",
          "expr": "mysql_global_status_threads_running",
          "legendFormat": "threads running"
        },
        {
          "maxDataPoints": 11000,
          "refId": "C",
          "expr": "rate(mysql_global_status_connections[1m])",
          "legendFormat": "new connections/sec"
        }
      ]
    },
    {
      "id": 35,
      "title": "MySQL Slow Queries / Row Locks",
      "type": "timeseries",
      "gridPos": {"x": 16, "y": 40, "w": 8, "h": 8},
      "fieldConfig": {"defaults": {"unit": "ops", "decimals": 3}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "rate(mysql_global_status_slow_queries[1m])",
          "legendFormat": "slow queries/sec"
        },
        {
          "maxDataPoints": 11000,
          "refId": "B",
          "expr": "rate(mysql_global_status_innodb_row_lock_waits[1m])",
          "legendFormat": "row lock waits/sec"
        }
      ]
    },
    {
      "id": 36,
      "title": "MySQL Buffer Pool Hit Ratio",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 48, "w": 8, "h": 8},
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 3, "min": 0, "max": 100}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "(1 - rate(mysql_global_status_innodb_buffer_pool_reads[5m]) / rate(mysql_global_status_innodb_buffer_pool_read_requests[5m])) * 100",
          "legendFormat": "hit ratio"
        }
      ]
    },
    {
      "id": 37,
      "title": "MySQL CPU",
      "type": "timeseries",
      "gridPos": {"x": 8, "y": 48, "w": 8, "h": 8},
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 2}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "docker_container_cpu_usage_cores{name=\"waito-mysql\"} * 100",
          "legendFormat": "cpu"
        }
      ]
    },
    {
      "id": 38,
      "title": "MySQL Memory",
      "type": "timeseries",
      "gridPos": {"x": 16, "y": 48, "w": 8, "h": 8},
      "fieldConfig": {"defaults": {"unit": "mbytes", "decimals": 2}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "docker_container_memory_usage_mb{name=\"waito-mysql\"}",
          "legendFormat": "memory"
        }
      ]
    },
    {
      "id": 39,
      "title": "MySQL Query Top 10 - Total Execution Time",
      "description": "Top query digests by MySQL execution time consumed per second over the last 5 minutes.",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 56, "w": 12, "h": 8},
      "fieldConfig": {"defaults": {"unit": "s", "decimals": 4}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "topk(10, rate(mysql_perf_schema_events_statements_seconds_total{schema!=\"\"}[5m]))",
          "legendFormat": "{{schema}} | {{digest_text}}"
        }
      ]
    },
    {
      "id": 46,
      "title": "MySQL Query Top 10 - Average Execution Time",
      "description": "Top query digests by average execution time over the last 5 minutes.",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 56, "w": 12, "h": 8},
      "fieldConfig": {"defaults": {"unit": "s", "decimals": 4}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "topk(10, rate(mysql_perf_schema_events_statements_seconds_total{schema!=\"\"}[5m]) / rate(mysql_perf_schema_events_statements_total{schema!=\"\"}[5m]))",
          "legendFormat": "{{schema}} | {{digest_text}}"
        }
      ]
    },
    {
      "id": 47,
      "title": "MySQL Query Top 10 - Queries per Second",
      "description": "Top query digests by executions per second over the last 5 minutes.",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 64, "w": 24, "h": 8},
      "fieldConfig": {"defaults": {"unit": "qps", "decimals": 3, "min": 0}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "topk(10, rate(mysql_perf_schema_events_statements_total{schema!=\"\"}[5m]))",
          "legendFormat": "{{schema}} | {{digest_text}}"
        }
      ]
    },
    {
      "id": 104,
      "title": "Redis",
      "type": "row",
      "collapsed": false,
      "gridPos": {"x": 0, "y": 72, "w": 24, "h": 1},
      "panels": []
    },
    {
      "id": 40,
      "title": "Redis Commands / Errors",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 73, "w": 8, "h": 8},
      "fieldConfig": {"defaults": {"unit": "ops", "decimals": 2}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "rate(redis_commands_processed_total[1m])",
          "legendFormat": "commands/sec"
        },
        {
          "maxDataPoints": 11000,
          "refId": "B",
          "expr": "sum(rate(redis_commands_failed_calls_total[1m])) by (cmd)",
          "legendFormat": "failed {{cmd}}"
        },
        {
          "maxDataPoints": 11000,
          "refId": "C",
          "expr": "rate(redis_total_error_replies[1m])",
          "legendFormat": "error replies/sec"
        }
      ]
    },
    {
      "id": 41,
      "title": "Redis Latency",
      "type": "timeseries",
      "gridPos": {"x": 8, "y": 73, "w": 8, "h": 8},
      "fieldConfig": {"defaults": {"unit": "us", "decimals": 2}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "redis_latency_percentiles_usec",
          "legendFormat": "{{cmd}} p{{quantile}}"
        },
        {
          "maxDataPoints": 11000,
          "refId": "B",
          "expr": "redis_last_slow_execution_duration_seconds * 1000000",
          "legendFormat": "last slow execution"
        }
      ]
    },
    {
      "id": 42,
      "title": "Redis Clients / Memory",
      "type": "timeseries",
      "gridPos": {"x": 16, "y": 73, "w": 8, "h": 8},
      "fieldConfig": {"defaults": {"decimals": 2}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "redis_connected_clients",
          "legendFormat": "connected clients"
        },
        {
          "maxDataPoints": 11000,
          "refId": "B",
          "expr": "redis_blocked_clients",
          "legendFormat": "blocked clients"
        },
        {
          "maxDataPoints": 11000,
          "refId": "C",
          "expr": "redis_memory_used_bytes / 1024 / 1024",
          "legendFormat": "memory MB"
        }
      ]
    },
    {
      "id": 105,
      "title": "Kafka",
      "type": "row",
      "collapsed": false,
      "gridPos": {"x": 0, "y": 89, "w": 24, "h": 1},
      "panels": []
    },
    {
      "id": 43,
      "title": "Cache Hit / Miss Increase (1m)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 81, "w": 8, "h": 8},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "round(sum(increase(waito_cache_hit_total[1m])) by (cache_name)) or sum(waito_cache_hit_total) by (cache_name)",
          "legendFormat": "hits {{cache_name}}"
        },
        {
          "maxDataPoints": 11000,
          "refId": "B",
          "expr": "round(sum(increase(waito_cache_miss_total[1m])) by (cache_name)) or sum(waito_cache_miss_total) by (cache_name)",
          "legendFormat": "misses {{cache_name}}"
        }
      ]
    },
    {
      "id": 44,
      "title": "Cache Hit Ratio by Cache",
      "type": "timeseries",
      "gridPos": {"x": 8, "y": 81, "w": 8, "h": 8},
      "fieldConfig": {"defaults": {"unit": "percentunit", "decimals": 3, "min": 0, "max": 1}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "(sum(increase(waito_cache_hit_total[1m])) by (cache_name) or sum(waito_cache_hit_total) by (cache_name)) / ((sum(increase(waito_cache_hit_total[1m])) by (cache_name) or sum(waito_cache_hit_total) by (cache_name)) + (sum(increase(waito_cache_miss_total[1m])) by (cache_name) or sum(waito_cache_miss_total) by (cache_name)))",
          "legendFormat": "{{cache_name}}"
        }
      ]
    },
    {
      "id": 45,
      "title": "Cache Stampede / Miss / Put Increase (1m)",
      "type": "timeseries",
      "gridPos": {"x": 16, "y": 81, "w": 8, "h": 8},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}},
      "targets": [
        {
          "maxDataPoints": 11000,
          "refId": "A",
          "expr": "round(sum(increase(waito_cache_miss_total[1m])) by (cache_name)) or sum(waito_cache_miss_total) by (cache_name)",
          "legendFormat": "misses {{cache_name}}"
        },
        {
          "maxDataPoints": 11000,
          "refId": "B",
          "expr": "round(sum(increase(waito_cache_put_total[1m])) by (cache_name)) or sum(waito_cache_put_total) by (cache_name)",
